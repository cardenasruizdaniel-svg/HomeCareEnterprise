# =========================================================
# HomeCare Enterprise - Variables de entorno
# Copiar este archivo como ".env" y completar los valores.
# =========================================================

# ---- Correo (SMTP) ----
# Ejemplo con Gmail: usar una "contraseña de aplicación",
# no la contraseña normal de la cuenta.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notificaciones@tudominio.com
SMTP_PASSWORD=
SMTP_FROM=notificaciones@tudominio.com
SMTP_FROM_NOMBRE=HomeCare IPS
SMTP_USE_TLS=1

# ---- WhatsApp Business Cloud API (Meta for Developers) ----
# Se obtiene creando una app de tipo "Business" en
# developers.facebook.com y activando el producto WhatsApp.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_API_VERSION=v20.0

# ---- General ----
PAIS_INDICATIVO_DEFECTO=57

# URL publica del servidor (necesaria para que WhatsApp pueda
# descargar el PDF adjunto de la orden medica). Dejar vacío
# en desarrollo local: WhatsApp enviará solo el texto, sin
# adjunto, hasta que el servidor tenga una URL publica.
PUBLIC_BASE_URL=

# ---- RIPS (Resolución 948 de 2026) ----
RIPS_NIT_PRESTADOR=
RIPS_CODIGO_HABILITACION=
RIPS_RAZON_SOCIAL=IPS HomeCare del Quindío
